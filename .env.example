# DevOps Security Monitor - Configuration Example

# GitHub (optional, for higher rate limit)
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# Slack Notifications (optional)
SLACK_WEBHOOK="https://hooks.slack.com/services/xxx/xxx/xxx"

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
TELEGRAM_CHAT_ID="123456789"

# Email Notifications (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-password"
EMAIL_TO="alerts@example.com"

# Alert Thresholds (1-10)
ALERT_THRESHOLD=7
CRITICAL_THRESHOLD=9

# Output
OUTPUT_DIR="/tmp"
LOG_FILE="/var/log/devops-monitor.log"

# Tools to Monitor (space-separated)
TOOLS_TO_CHECK="trivy docker kubernetes terraform ansible jenkins gitlab github-actions"

# Reddit Subreddits
SUBREDDITS="devops cybersecurity programming"

# Notification Channels (comma-separated)
CHANNELS="slack,telegram"
